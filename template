# Template file for 'vscode-bin'
pkgname=vscode-bin
version=1.124.0
revision=1
archs="x86_64"
short_desc="Visual Studio Code - Code editing. Redefined (precompiled binary)"
maintainer="Mark <mark@example.com>"
license="MIT"
homepage="https://code.visualstudio.com"
changelog="https://code.visualstudio.com/updates"
distfiles="https://update.code.visualstudio.com/${version}/linux-x64/stable>vscode-${version}-x64.tar.gz"
checksum="79488ea5224271d0de4a4dcd46fe1fc4ddd14ab1b86b1181e94e738790c46577"

create_wrksrc=yes
lib32disabled=yes
nostrip=yes
hostmakedepends="tar"
depends="libX11 libxkbfile libsecret gtk+3 libXtst nss alsa-lib"
conflicts="vscode>=0"

shlib_provides="libffmpeg.so libmsalruntime.so libvulkan.so.1"
allow_unknown_shlibs=yes

do_install() {
	vmkdir opt/vscode
	vcopy "VSCode-linux-x64/*" opt/vscode

	# Create wrapper script for /usr/bin
	cat > code-wrapper <<-EOF
	#!/bin/sh
	exec /opt/vscode/bin/code "\$@"
	EOF
	vbin code-wrapper code

	# Install desktop files and icons
	vinstall "${FILESDIR}/vscode.desktop" 644 usr/share/applications
	if [ -f VSCode-linux-x64/resources/app/resources/linux/code.png ]; then
		vinstall VSCode-linux-x64/resources/app/resources/linux/code.png 644 \
			usr/share/pixmaps vscode.png
	fi
	vinstall "${FILESDIR}/vscode-url-handler.desktop" 644 usr/share/applications
}
